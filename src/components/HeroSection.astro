---
import { HOME_PAGE_CONTENT } from "../utils/siteContent";
---

<section class="relative overflow-hidden layout bound-x scheme-default py-[32px] m-0 border-0">
  <!-- Glowing radial background -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-timefold-primary/20 via-timefold-dark to-timefold-dark -z-10 pointer-events-none"></div>
  
  <div class="relative max-w-screen-vp10 pb-16 pt-14 sm:pb-28 sm:pt-28 mx-auto text-center" data-aos="fade-up" data-aos-duration="1000">
    <h1 class="leading-[1.1] tracking-tight text-white text-5xl md:text-7xl font-bold mb-6">
      Optimize complex
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-timefold-primary to-timefold-accent">scheduling</span><br />
      —one API call away
    </h1>
    <p class="mx-auto leading-relaxed text-slate-400 max-w-2xl text-lg md:text-xl mb-10">
      The intelligent scheduling optimization platform for workforce management: route vehicles, schedule jobs, and assign employees optimally in real time.
    </p>
    
    <div class="flex flex-col items-center justify-center gap-4 sm:flex-row inline-flex w-fit mx-auto">
      <a
        href="#start"
        class="rounded-full bg-timefold-accent px-8 py-4 text-center font-semibold text-timefold-dark shadow-glow-accent transition hover:bg-emerald-400 hover:scale-105"
      >
        {HOME_PAGE_CONTENT.requestTrialLabel}
      </a>
      <a
        href="#models"
        class="rounded-full border border-slate-600 bg-timefold-card px-8 py-4 text-center font-medium text-slate-300 transition hover:border-timefold-primary hover:text-white"
      >
        {HOME_PAGE_CONTENT.exploreApisLabel}
      </a>
    </div>

    <!-- API preview visual block -->
    <div class="mt-16 sm:mt-24 mx-auto max-w-4xl border border-timefold-border bg-timefold-card rounded-2xl p-4 shadow-xl backdrop-blur-sm text-left">
      <div class="flex items-center gap-2 mb-4 px-2">
        <div class="w-3 h-3 rounded-full bg-red-500"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
        <div class="w-3 h-3 rounded-full bg-green-500"></div>
        <span class="ml-4 text-xs text-slate-500 font-mono">POST /api/v1/optimize/schedule</span>
      </div>
      <pre class="overflow-x-auto p-4 bg-black/40 rounded-xl rounded-t-none text-sm font-mono text-emerald-300 border-t border-timefold-border/50"><code set:text={`{
  "vehicles": [
    { "id": "V1", "capacity": [100] },
    { "id": "V2", "capacity": [120] }
  ],
  "visits": [
    { "id": "Job1", "location": [51.5, -0.1], "demand": [20] },
    ...
  ]
}`}></code></pre>
    </div>
  </div>
</section>
