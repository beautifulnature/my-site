---
const { items = [], className = "" } = Astro.props as {
  items: Array<{ label: string; href: string; active?: boolean }>;
  className?: string;
};

const getChipClass = (active?: boolean) => {
  const base =
    "inline-flex items-center rounded-full text-base uppercase font-bold tracking-wide transition-colors duration-200";
  const inactive = "";
  const activeClass = "is-active";
  return `${base} ${active ? activeClass : inactive}`;
};
---

{
  items.map((item) => (
    <button class="c-label c-label--small c-label--light-grey c-label--lower c-label--filter">
      <a href={item.href} class={getChipClass(item.active)}>
        <span class="c-label__text">{item.label}</span>
      </a>
    </button>
  ))
}
