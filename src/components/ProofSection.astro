---
import ResourceIcons from "./ResourceIcons.astro";
import { HOME_PAGE_CONTENT } from "../utils/siteContent";
---
<section id="proof" class="layout bound-x scheme-default py-[32px] m-0 border-0">
  <div class="max-w-screen-vp10 mx-auto mb-16 text-center">
    <span class="text-timefold-accent uppercase tracking-wider font-semibold text-sm" data-aos="fade-up">Customer Stories</span>
    <h2 class="tracking-tight text-white text-3xl md:text-5xl font-bold mt-3 mb-4" data-aos="fade-up" data-aos-delay="50">Proof in practice</h2>
    <p class="text-slate-400 text-lg" data-aos="fade-up" data-aos-delay="100">Their words, not ours.</p>
  </div>
  
  <div class="grid vp7:grid-cols-2 vp9:grid-cols-3 gap-4 text-left" data-aos="fade-up" data-aos-delay="150">
      <blockquote class="bg-timefold-card border border-timefold-border p-8 rounded-2xl flex flex-col gap-4 relative">
         <span class="absolute top-8 right-8 text-timefold-primary/20"><ResourceIcons name="quote" size={40} /></span>
         <p class="text-slate-300 text-lg italic leading-relaxed z-10">"{HOME_PAGE_CONTENT.testimonialLeadQuote}"</p>
         <div class="border-t border-timefold-border/50 pt-4 mt-auto">
            <p class="text-white font-semibold">Technical Business Lead</p>
            <div class="h-6 mt-2 opacity-70">
               <img src="/logos/servicetrade.svg" class="h-full object-contain filter invert" alt="ServiceTrade" />
            </div>
         </div>
      </blockquote>
      
      <blockquote class="bg-timefold-card border border-timefold-border p-8 rounded-2xl flex flex-col gap-4 relative">
         <span class="absolute top-8 right-8 text-timefold-primary/20"><ResourceIcons name="quote" size={40} /></span>
         <p class="text-slate-300 text-lg italic leading-relaxed z-10">"Time-to-market dropped fast with practical support and a partnership that worked as one team."</p>
         <div class="border-t border-timefold-border/50 pt-4 mt-auto">
            <p class="text-white font-semibold">Product Director</p>
            <div class="h-6 mt-2 opacity-70">
               <img src="/logos/adp.svg" class="h-full object-contain filter invert" alt="ADP" />
            </div>
         </div>
      </blockquote>
      
      <blockquote class="bg-timefold-card border border-timefold-border p-8 rounded-2xl flex flex-col gap-4 relative">
         <span class="absolute top-8 right-8 text-timefold-primary/20"><ResourceIcons name="quote" size={40} /></span>
         <p class="text-slate-300 text-lg italic leading-relaxed z-10">"We were production-ready with real data in days, not months, thanks to a strong platform foundation."</p>
         <div class="border-t border-timefold-border/50 pt-4 mt-auto">
            <p class="text-white font-semibold">Chief Architect</p>
            <div class="h-6 mt-2 opacity-70">
               <img src="/logos/lufthansa.svg" class="h-full object-contain filter invert" alt="Lufthansa" />
            </div>
         </div>
      </blockquote>
    </div>
  </div>
</section>
