---
// SearchModal.astro — site-wide search triggered by Ctrl+K / Cmd+K
---

<!-- Trigger button (rendered inline; also wired via keyboard shortcut) -->
<button
  id="search-trigger"
  aria-label="Search (Ctrl+K)"
  title="Search (Ctrl+K)"
  class="search-trigger-btn"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
  </svg>
  <span class="search-trigger-label">Search</span>
  <kbd class="search-trigger-kbd">⌘K</kbd>
</button>

<!-- Modal overlay -->
<div id="search-overlay" class="search-overlay" role="dialog" aria-modal="true" aria-label="Site search" hidden>
  <div class="search-backdrop" id="search-backdrop"></div>

  <div class="search-panel">
    <!-- Input row -->
    <div class="search-input-row">
      <svg class="search-input-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input
        id="search-input"
        type="text"
        autocomplete="off"
        spellcheck="false"
        placeholder="Search pages, blog, docs, math…"
        class="search-input"
        aria-autocomplete="list"
        aria-controls="search-results"
        autocorrect="off"
        autocapitalize="off"
      />
      <kbd class="search-esc-hint">Esc</kbd>
    </div>

    <!-- Results / empty / no-results -->
    <div id="search-body" class="search-body">
      <div id="search-empty" class="search-state">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <p>Start typing to search across all content</p>
      </div>

      <div id="search-no-results" class="search-state" hidden>
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          <line x1="8" y1="8" x2="14" y2="14" stroke-width="2" stroke="#ef4444"/>
        </svg>
        <p>No results for "<span id="search-no-results-query"></span>"</p>
      </div>

      <ul id="search-results" class="search-results" role="listbox" hidden></ul>
    </div>

    <!-- Footer -->
    <div class="search-footer">
      <span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
      <span><kbd>↵</kbd> open</span>
      <span><kbd>Esc</kbd> close</span>
    </div>
  </div>
</div>

<script>
  import Fuse from 'fuse.js';

  // ── Types ────────────────────────────────────────────────────────
  interface SearchEntry {
    type: string;
    title: string;
    description?: string;
    tags?: string[];
    href: string;
    author?: string;
  }

  // ── State ────────────────────────────────────────────────────────
  let fuse: Fuse<SearchEntry> | null = null;
  let activeIdx = -1;
  let currentResults: SearchEntry[] = [];

  // ── Elements ─────────────────────────────────────────────────────
  const overlay     = document.getElementById('search-overlay')!;
  const backdrop    = document.getElementById('search-backdrop')!;
  const input       = document.getElementById('search-input') as HTMLInputElement;
  const resultsList = document.getElementById('search-results') as HTMLUListElement;
  const emptyState  = document.getElementById('search-empty')!;
  const noResults   = document.getElementById('search-no-results')!;
  const noResultsQ  = document.getElementById('search-no-results-query')!;
  const trigger     = document.getElementById('search-trigger')!;

  // ── Load index ───────────────────────────────────────────────────
  async function loadIndex() {
    if (fuse) return;
    try {
      const res = await fetch('/api/search.json');
      const data: SearchEntry[] = await res.json();
      fuse = new Fuse(data, {
        keys: [
          { name: 'title',       weight: 0.5 },
          { name: 'description', weight: 0.3 },
          { name: 'tags',        weight: 0.2 },
        ],
        threshold: 0.35,
        includeScore: true,
        minMatchCharLength: 2,
      });
    } catch (e) {
      console.error('Search index failed to load', e);
    }
  }

  // ── Open / close ─────────────────────────────────────────────────
  function openModal() {
    overlay.removeAttribute('hidden');
    input.value = '';
    showEmpty();
    activeIdx = -1;
    setTimeout(() => input.focus(), 50);
    loadIndex();
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    overlay.setAttribute('hidden', '');
    document.body.style.overflow = '';
    activeIdx = -1;
  }

  // ── Category metadata ─────────────────────────────────────────────
  const CATEGORY: Record<string, { label: string; color: string }> = {
    blog:       { label: 'Blog',       color: '#16a34a' },
    docs:       { label: 'Docs',       color: '#2563eb' },
    'use-case': { label: 'Use Case',   color: '#d97706' },
    math:       { label: 'Math',       color: '#7c3aed' },
    page:       { label: 'Page',       color: '#6b7280' },
  };

  // ── Render results ────────────────────────────────────────────────
  function showEmpty() {
    emptyState.removeAttribute('hidden');
    noResults.setAttribute('hidden', '');
    resultsList.setAttribute('hidden', '');
    resultsList.innerHTML = '';
  }

  function showNoResults(query: string) {
    emptyState.setAttribute('hidden', '');
    noResultsQ.textContent = query;
    noResults.removeAttribute('hidden');
    resultsList.setAttribute('hidden', '');
    resultsList.innerHTML = '';
  }

  function renderResults(results: SearchEntry[]) {
    currentResults = results;
    activeIdx = -1;
    emptyState.setAttribute('hidden', '');
    noResults.setAttribute('hidden', '');
    resultsList.removeAttribute('hidden');
    resultsList.innerHTML = '';

    results.forEach((item, i) => {
      const cat = CATEGORY[item.type] ?? CATEGORY['page'];
      const li = document.createElement('li');
      li.setAttribute('role', 'option');
      li.setAttribute('aria-selected', 'false');
      li.dataset.idx = String(i);
      li.className = 'search-result-item';
      li.innerHTML = `
        <a href="${item.href}" class="search-result-link" tabindex="-1">
          <span class="search-result-badge" style="--badge-color:${cat.color}">${cat.label}</span>
          <span class="search-result-text">
            <span class="search-result-title">${item.title}</span>
            ${item.description ? `<span class="search-result-desc">${item.description}</span>` : ''}
          </span>
          <svg class="search-result-arrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>`;

      li.addEventListener('mouseenter', () => setActive(i));
      li.querySelector('a')!.addEventListener('click', closeModal);
      resultsList.appendChild(li);
    });
  }

  // ── Keyboard navigation ───────────────────────────────────────────
  function setActive(idx: number) {
    const items = resultsList.querySelectorAll<HTMLLIElement>('.search-result-item');
    items.forEach((el, i) => {
      el.classList.toggle('is-active', i === idx);
      el.setAttribute('aria-selected', String(i === idx));
    });
    activeIdx = idx;
    if (idx >= 0) items[idx]?.scrollIntoView({ block: 'nearest' });
  }

  // ── Input handler ─────────────────────────────────────────────────
  input.addEventListener('input', () => {
    const q = input.value.trim();
    if (!q) { showEmpty(); return; }
    if (!fuse) { showEmpty(); return; }
    const raw = fuse.search(q, { limit: 12 });
    if (raw.length === 0) { showNoResults(q); return; }
    renderResults(raw.map(r => r.item));
  });

  // ── Unified document-level key handler ───────────────────────────
  // Handling at document level ensures arrow keys always fire even when
  // the browser's <input> default behaviour would otherwise consume them.
  document.addEventListener('keydown', (e) => {
    // Ctrl/Cmd+K — toggle modal
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      overlay.hasAttribute('hidden') ? openModal() : closeModal();
      return;
    }

    // Keys below only apply when modal is open
    if (overlay.hasAttribute('hidden')) return;

    if (e.key === 'Escape') {
      e.preventDefault();
      closeModal();
      return;
    }

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      setActive(Math.min(activeIdx + 1, currentResults.length - 1));
      return;
    }

    if (e.key === 'ArrowUp') {
      e.preventDefault();
      setActive(Math.max(activeIdx - 1, 0));
      return;
    }

    if (e.key === 'Enter') {
      e.preventDefault();
      if (activeIdx >= 0 && currentResults[activeIdx]) {
        const href = currentResults[activeIdx].href;
        closeModal();
        window.location.href = href;
      }
    }
  });

  // ── Trigger button ────────────────────────────────────────────────
  trigger.addEventListener('click', openModal);

  // ── Backdrop click ────────────────────────────────────────────────
  backdrop.addEventListener('click', closeModal);

  // ── Show OS-appropriate shortcut on trigger ───────────────────────
  const isMac = /Mac|iPhone|iPad/.test(navigator.platform || navigator.userAgent);
  const kbdEl = trigger.querySelector('.search-trigger-kbd');
  if (kbdEl) kbdEl.textContent = isMac ? '⌘K' : 'Ctrl+K';
</script>

<style>
  /* ── Trigger button ──────────────────────────────────────────────── */
  .search-trigger-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.65rem 0.3rem 0.5rem;
    border: 1px solid var(--scheme-border, #e5e7eb);
    border-radius: 0.5rem;
    background: transparent;
    color: var(--scheme-text, #6b7280);
    cursor: pointer;
    font-size: 0.8125rem;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .search-trigger-btn:hover {
    border-color: #5306F7;
    color: #5306F7;
    background: rgba(83,6,247,0.05);
  }
  .search-trigger-label {
    display: none;
  }
  @media (min-width: 768px) {
    .search-trigger-label { display: inline; }
  }
  .search-trigger-kbd {
    display: none;
    background: var(--scheme-surface, #f3f4f6);
    border: 1px solid var(--scheme-border, #e5e7eb);
    border-radius: 0.3rem;
    padding: 0 0.35rem;
    font-size: 0.7rem;
    font-family: inherit;
    color: #9ca3af;
    line-height: 1.5;
  }
  @media (min-width: 960px) {
    .search-trigger-kbd { display: inline; }
  }

  /* ── Overlay & backdrop ──────────────────────────────────────────── */
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: clamp(4rem, 10vh, 8rem);
    padding-inline: 1rem;
  }
  .search-overlay[hidden] { display: none !important; }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  /* ── Search panel ────────────────────────────────────────────────── */
  .search-panel {
    position: relative;
    width: 100%;
    max-width: 620px;
    background: #fff;
    border-radius: 1rem;
    box-shadow: 0 24px 64px -12px rgba(0,0,0,0.35);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: calc(100vh - 10rem);
  }
  :global(html.dark) .search-panel {
    background: #0f172a;
    border: 1px solid #1e293b;
  }

  /* ── Input row ───────────────────────────────────────────────────── */
  .search-input-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid #e5e7eb;
  }
  :global(html.dark) .search-input-row { border-color: #1e293b; }

  .search-input-icon {
    flex-shrink: 0;
    color: #9ca3af;
  }

  .search-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-size: 1rem;
    color: #111827;
    min-width: 0;
  }
  :global(html.dark) .search-input { color: #f1f5f9; }
  .search-input::placeholder { color: #9ca3af; }
  .search-input::-webkit-search-cancel-button { display: none; }

  .search-esc-hint {
    flex-shrink: 0;
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    border-radius: 0.3rem;
    padding: 0.1rem 0.4rem;
    font-size: 0.7rem;
    font-family: inherit;
    color: #9ca3af;
  }
  :global(html.dark) .search-esc-hint { background: #1e293b; border-color: #334155; }

  /* ── Body (states + results) ─────────────────────────────────────── */
  .search-body {
    overflow-y: auto;
    flex: 1;
  }

  .search-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 2.5rem 1rem;
    color: #9ca3af;
    font-size: 0.9rem;
    text-align: center;
  }
  .search-state[hidden] { display: none; }
  .search-state svg { opacity: 0.4; }

  /* ── Results list ────────────────────────────────────────────────── */
  .search-results {
    list-style: none;
    padding: 0.5rem;
    margin: 0;
  }
  .search-results[hidden] { display: none; }

  .search-result-item { border-radius: 0.5rem; }
  .search-result-item.is-active { background: #f5f3ff; }
  :global(html.dark) .search-result-item.is-active { background: #1e1b4b; }

  .search-result-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 0.75rem;
    text-decoration: none;
    border-radius: 0.5rem;
    width: 100%;
  }

  .search-result-badge {
    flex-shrink: 0;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.5rem;
    border-radius: 99px;
    color: var(--badge-color);
    background: color-mix(in srgb, var(--badge-color) 12%, transparent);
    white-space: nowrap;
  }

  .search-result-text {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .search-result-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: #111827;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  :global(html.dark) .search-result-title { color: #f1f5f9; }

  .search-result-desc {
    font-size: 0.775rem;
    color: #6b7280;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  :global(html.dark) .search-result-desc { color: #64748b; }

  .search-result-arrow {
    flex-shrink: 0;
    color: #d1d5db;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .search-result-item.is-active .search-result-arrow { opacity: 1; color: #5306F7; }

  /* ── Footer ──────────────────────────────────────────────────────── */
  .search-footer {
    display: flex;
    gap: 1.25rem;
    padding: 0.6rem 1rem;
    border-top: 1px solid #e5e7eb;
    font-size: 0.72rem;
    color: #9ca3af;
  }
  :global(html.dark) .search-footer { border-color: #1e293b; }

  .search-footer kbd {
    display: inline-block;
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    border-radius: 0.25rem;
    padding: 0 0.3rem;
    font-family: inherit;
    font-size: 0.68rem;
    color: #374151;
    margin-right: 0.2rem;
  }
  :global(html.dark) .search-footer kbd {
    background: #1e293b;
    border-color: #334155;
    color: #94a3b8;
  }
</style>
