>
  <nav class="flex flex-1 items-center justify-between h-[56px]">
    <h2 class="sr-only">Navigation</h2>
    <div class="flex items-center">
      <a
        href="http://localhost:4321/"
        aria-label="Timefold logo"
        class="block h-8 w-auto"
      >
        <ResourceIcons name="timefold-logo" />
        <!-- {SITE_CONTENT.siteName} -->
      </a>
    </div>
    <div
      id="site-header-navigation"
      class="flex-1 items-center justify-center hidden vp9:flex"
    >
      <ul class="flex gap-4">
        <li>
          <button
            class="flex items-center gap-1 px-3 py-2 rounded-md hover:bg-slate-100 focus:outline-none"
          >
            <span>Use cases</span>
            <svg
              class="w-4 h-4"
              fill="currentColor"
