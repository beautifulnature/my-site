          >
            <span>Resources</span>
            <svg
              class="w-4 h-4"
              fill="currentColor"
              viewBox="0 0 448 512"
              aria-hidden="true"
              ><path
                d="M199 401c9.4 9.4 24.6 9.4 33.9 0L425 209c9.4-9.4 9.4-24.6 0-33.9s-24.6-9.4-33.9 0l-175 175L41 175c-9.4-9.4-24.6-9.4-33.9 0s-9.4 24.6 0 33.9L199 401z"
              ></path></svg
