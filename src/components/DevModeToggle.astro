---
<button id="dev-mode-toggle" class="flex items-center justify-center p-2.5 rounded-full hover:bg-gray-100 dark:hover:bg-timefold-card text-gray-600 dark:text-slate-300 transition-colors focus:outline-none focus:ring-2 focus:ring-[#5A32FA] dark:focus:ring-[#10b981]" aria-label="Toggle Developer Mode" title="Developer Layout Mode">
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
  </svg>
</button>

<script>
  const handleDevToggle = () => {
    document.documentElement.classList.toggle("dev-mode");
    const isDev = document.documentElement.classList.contains("dev-mode");
    localStorage.setItem("dev-mode", isDev ? "true" : "false");
  }

  document.querySelectorAll('#dev-mode-toggle').forEach(btn => {
    btn.addEventListener('click', handleDevToggle);
  });

  // Init state
  if (typeof localStorage !== 'undefined' && localStorage.getItem("dev-mode") === "true") {
      document.documentElement.classList.add("dev-mode");
  }
</script>
