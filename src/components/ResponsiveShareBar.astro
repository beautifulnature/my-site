---
import ResourceIcons from "./ResourceIcons.astro";

const { url, title } = Astro.props;

const pageUrl = url;
const tweetText = encodeURIComponent(title);

const twitterShare = `https://twitter.com/intent/tweet?url=${encodeURIComponent(pageUrl)}&text=${tweetText}`;
const linkedinShare = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`;
const hackerNewsShare = `https://news.ycombinator.com/submitlink?u=${encodeURIComponent(pageUrl)}&t=${tweetText}`;
---

<span
  class="flex h-8 w-8 items-center justify-center rounded-full border border-slate-300 dark:border-white/15 text-slate-700 dark:text-slate-300"
>
  <ResourceIcons name="share" size={16} color="currentColor" />
</span>

<a
  href={twitterShare}
  target="_blank"
  rel="noreferrer"
  class="flex items-center justify-center rounded-full border border-slate-300 dark:border-white/15 text-slate-600 dark:text-slate-300 p-2 transition-colors hover:bg-tf-purple hover:border-tf-purple hover:text-white"
  aria-label="Share on Twitter / X"
>
  <ResourceIcons name="twitter" size={16} color="currentColor" />
</a>

<a
  href={linkedinShare}
  target="_blank"
  rel="noreferrer"
  class="flex items-center justify-center rounded-full border border-slate-300 dark:border-white/15 text-slate-600 dark:text-slate-300 p-2 transition-colors hover:bg-tf-purple hover:border-tf-purple hover:text-white"
  aria-label="Share on LinkedIn"
>
  <ResourceIcons name="linkedin" size={16} color="currentColor" />
</a>

<a
  href={hackerNewsShare}
  target="_blank"
  rel="noreferrer"
  class="flex items-center justify-center rounded-full border border-slate-300 dark:border-white/15 text-slate-600 dark:text-slate-300 p-2 transition-colors hover:bg-tf-purple hover:border-tf-purple hover:text-white"
  aria-label="Share on Hacker News"
>
  <ResourceIcons name="hackernews" size={16} color="currentColor" />
</a>
