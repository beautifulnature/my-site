---
import ResourceIcons from "./ResourceIcons.astro";
---
<section id="models" class="layout bound-x scheme-default py-[32px] m-0 border-0 relative">
  <div class="layout-section-y">
    <div class="max-w-screen-vp10 mx-auto text-center mb-12">
      <span class="text-timefold-accent uppercase tracking-wider font-semibold text-sm" data-aos="fade-up">Planning Models</span>
      <h2 class="tracking-tight text-white text-3xl md:text-5xl font-bold mt-3 mb-4" data-aos="fade-up" data-aos-delay="50">
        Real-world and ready-to-use APIs
      </h2>
      <p class="max-w-3xl mx-auto text-slate-400 text-lg" data-aos="fade-up" data-aos-delay="100">
        Get optimization out of the box. We took care of the complexity.
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-y-6 md:gap-y-0" data-aos="fade-up" data-aos-delay="150">
      <article class="w-full vp7:w-1/3 bg-timefold-card border border-timefold-border p-8 rounded-2xl flex flex-col gap-4 group hover:-translate-y-1 hover:border-timefold-primary hover:shadow-glow-primary transition-all duration-300">
        <ResourceIcons name="quote" size={30} />
        <p class="text-slate-300 h-20">Assign the right technician at the right time while minimizing travel.</p>
        <div class="border-t border-timefold-border/50 pt-4 mt-auto">
          <p class="text-white font-semibold">Field Service Routing</p>
          <div class="h-8 mt-2 opacity-70 group-hover:opacity-100 transition-opacity">
            <img src="/logos/servicetrade.svg" class="h-full object-contain filter invert" alt="ServiceTrade" />
          </div>
        </div>
      </article>
      
      <article class="w-full vp7:w-1/3 bg-timefold-card border border-timefold-border p-8 rounded-2xl flex flex-col gap-4 group hover:-translate-y-1 hover:border-timefold-primary hover:shadow-glow-primary transition-all duration-300 mx-0 vp7:mx-2">
        <ResourceIcons name="quote" size={30} />
        <p class="text-slate-300 h-20">Generate fair and compliant shifts across locations and roles.</p>
        <div class="border-t border-timefold-border/50 pt-4 mt-auto">
          <p class="text-white font-semibold">Employee Shift Scheduling</p>
          <div class="h-8 mt-2 opacity-70 group-hover:opacity-100 transition-opacity">
            <img src="/logos/adp.svg" class="h-full object-contain filter invert" alt="ADP" />
          </div>
        </div>
      </article>
      
      <article class="w-full vp7:w-1/3 bg-timefold-card border border-timefold-border p-8 rounded-2xl flex flex-col gap-4 group hover:-translate-y-1 hover:border-timefold-primary hover:shadow-glow-primary transition-all duration-300">
        <ResourceIcons name="quote" size={30} />
        <p class="text-slate-300 h-20">Optimize depot-to-customer deliveries with capacity-aware routing.</p>
        <div class="border-t border-timefold-border/50 pt-4 mt-auto">
          <p class="text-white font-semibold">Last-Mile Delivery Routing</p>
          <div class="h-8 mt-2 opacity-70 group-hover:opacity-100 transition-opacity">
            <img src="/logos/lufthansa.svg" class="h-full object-contain filter invert" alt="Lufthansa" />
          </div>
        </div>
      </article>
    </div>
  </div>
</section>
