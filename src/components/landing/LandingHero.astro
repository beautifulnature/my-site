---
---
<section class="bg-white dark:bg-[#0b0f19] layout bound-x py-[32px] m-0 border-0 overflow-hidden transition-colors duration-300 scheme-default">
  <div class="w-full h-full">
    <div class="flex flex-col lg:flex-row gap-16 items-center">
      <div class="flex-1 lg:max-w-xl xl:max-w-2xl text-center lg:text-left">
        <h1 class="typo-h1 mb-8 transition-colors duration-300">
          Optimize complex <span class="text-[var(--scheme-accent)] dark:drop-shadow-[0_0_10px_rgba(90,50,250,0.5)]">route scheduling</span><br/>—one API call away
        </h1>
        <p class="typo-p mb-10 max-w-xl mx-auto lg:mx-0 transition-colors duration-300">
          Achieve world-class routing algorithms within your software, accelerating time-to-market while decreasing development overhead and risks.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href="#" class="px-8 py-4 text-center text-white bg-[#5A32FA] rounded font-bold hover:bg-[#492bc6] transition-all shadow-[0_0_20px_rgba(90,50,250,0.3)] hover:-translate-y-1">Start free trial</a>
          <a href="#" class="px-8 py-4 text-center text-gray-800 dark:text-slate-200 bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded font-bold hover:bg-gray-50 dark:hover:bg-white/10 transition-all hover:-translate-y-1">Talk to sales</a>
        </div>
      </div>
      
      <!-- Right Side Visual -->
      <div class="flex-1 w-full flex justify-center lg:justify-end relative">
        <div class="relative w-full max-w-lg aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl border border-gray-100 dark:border-white/10 transform rotate-1 hover:rotate-0 transition duration-500 group">
           <!-- Utilizing unplash to mimic the delivery dashboard image -->
           <img src="https://images.unsplash.com/photo-1586864387789-228ae0f6becb?auto=format&fit=crop&q=80&w=800" alt="Delivery Van Dashboard" class="object-cover w-full h-full filter brightness-105 dark:brightness-90 transition-all duration-300" />
           
           <!-- Overlay styling to give it the dashboard UI feel inside the image -->
           <div class="absolute bottom-6 left-0 right-0 flex flex-wrap justify-center gap-3 px-4 z-10 w-full transition-transform duration-500 group-hover:-translate-y-2">
              <span class="bg-white/95 dark:bg-[#0b0f19]/90 backdrop-blur-md text-xs font-bold px-4 py-2 rounded-full shadow-lg text-gray-700 dark:text-slate-200 tracking-tight flex items-center gap-2 border border-transparent dark:border-white/10 transition-colors duration-300">
                 <span class="w-2 h-2 rounded-full bg-emerald-500 dark:shadow-[0_0_5px_#10b981]"></span>
                 Vehicle 1: 85%
              </span>
              <span class="bg-white/95 dark:bg-[#0b0f19]/90 backdrop-blur-md text-xs font-bold px-4 py-2 rounded-full shadow-lg text-gray-700 dark:text-slate-200 tracking-tight flex items-center gap-2 border border-transparent dark:border-white/10 transition-colors duration-300">
                 <span class="w-2 h-2 rounded-full bg-blue-500 dark:shadow-[0_0_5px_#3b82f6]"></span>
                 Time: -15%
              </span>
              <span class="bg-white/95 dark:bg-[#0b0f19]/90 backdrop-blur-md text-xs font-bold px-4 py-2 rounded-full shadow-lg text-[#5A32FA] dark:text-[#a78bfa] tracking-tight flex items-center gap-2 border border-transparent dark:border-white/10 transition-colors duration-300">
                 <span class="w-2 h-2 rounded-full bg-[#5A32FA] dark:shadow-[0_0_8px_#a78bfa]"></span>
                 Optimized
              </span>
           </div>
        </div>
      </div>
    </div>
  </div>
</section>
