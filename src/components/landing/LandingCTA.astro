<section class="bg-white dark:bg-[#0b0f19] layout bound-x py-[32px] m-0 border-0 transition-colors duration-300 scheme-default">
  <div class="w-full h-full">
    <div class="bg-gradient-to-r from-[#501dee] via-[#5A32FA] to-[#3a1da3] dark:from-[#3617a2] dark:to-[#170a46] rounded-[3rem] p-12 md:p-24 text-center relative overflow-hidden shadow-[0_30px_60px_-15px_rgba(90,50,250,0.4)] dark:shadow-[0_20px_50px_-10px_rgba(0,0,0,0.8)] transition-all duration-300 scheme-purple">
      <!-- Overlay Grid Pattern / Glows -->
      <div class="absolute inset-0 opacity-[0.08]" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 60px 60px;"></div>
      <div class="absolute -top-64 -left-64 w-[500px] h-[500px] bg-white/20 dark:bg-white/5 blur-[120px] rounded-full pointer-events-none transition-opacity duration-300"></div>
      
      <div class="relative z-10 flex flex-col items-center">
        <span class="typo-label opacity-90 mb-6 block">Ready to start optimizing?</span>
        <h2 class="typo-h2 mb-12 max-w-4xl mx-auto drop-shadow-sm">
          Get more out of your resources, fast.
        </h2>
        <div class="flex flex-col sm:flex-row gap-6">
          <a href="#" class="px-10 py-5 text-center text-[#5A32FA] dark:text-[#501dee] bg-white rounded-xl font-bold hover:bg-gray-50 shadow-xl transition-all hover:scale-105 hover:-translate-y-1 text-lg">Start free trial</a>
          <a href="#" class="px-10 py-5 text-center text-white bg-white/5 border-2 border-white/20 backdrop-blur-sm rounded-xl font-bold hover:bg-white/10 transition-all text-lg hover:border-white/40">Talk to sales</a>
        </div>
      </div>
    </div>
  </div>
</section>
