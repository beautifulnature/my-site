---
---
<section class="bg-gray-50 dark:bg-[#0f1523] layout bound-x py-[32px] m-0 border-0 transition-colors duration-300 scheme-default">
  <div class="w-full h-full">
    <div class="max-w-screen-vp10 mx-auto text-center mb-16">
      <h2 class="typo-h2 transition-colors duration-300">Solve on a single, powerful <span class="text-[var(--scheme-accent)]">platform</span></h2>
      <p class="typo-p mt-4 max-w-2xl mx-auto transition-colors duration-300">Combine routing, assigning, and scheduling into one API motion, built directly for developers.</p>
    </div>
    
    <div class="grid vp7:grid-cols-2 vp9:grid-cols-3 gap-4">
       <!-- Card 1 (Purple) -->
       <div class="bg-[var(--scheme-shade)] rounded-[2rem] p-10 shadow-xl dark:shadow-[0_20px_50px_-10px_rgba(0,0,0,0.7)] flex flex-col items-center justify-center text-center relative overflow-hidden group transition-colors duration-300 scheme-purple">
          <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent pointer-events-none transition-colors duration-300"></div>
          <svg class="w-24 h-24 text-[var(--scheme-contrast)] mb-8 transform group-hover:-translate-y-2 transition duration-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>
          <h3 class="typo-h3 relative z-10 transition-colors duration-300">Fully managed enterprise cloud</h3>
       </div>
       
       <!-- Card 2 -->
       <div class="bg-[var(--scheme-shade)] rounded-[2rem] p-10 border border-[var(--scheme-border)] shadow-sm dark:shadow-none flex flex-col items-center text-center group line-clamp-2 hover:shadow-md transition-all duration-300">
          <div class="w-full h-40 mb-8 flex items-center justify-center relative justify-center overflow-hidden">
             <!-- Connect nodes mock -->
             <div class="absolute w-full h-[1px] bg-[var(--scheme-border)] rotate-[20deg] transition-colors duration-300"></div>
             <div class="absolute w-full h-[1px] bg-[var(--scheme-border)] -rotate-[20deg] transition-colors duration-300"></div>
             <div class="w-14 h-14 rounded-full bg-orange-50 dark:bg-orange-900/40 border border-orange-100 dark:border-orange-900 flex items-center justify-center z-10 absolute left-[15%] top-[15%] group-hover:scale-110 transition duration-500 shadow-sm"><span class="w-4 h-4 bg-orange-400 rounded-full"></span></div>
             <div class="w-14 h-14 rounded-full bg-emerald-50 dark:bg-emerald-900/40 border border-emerald-100 dark:border-emerald-900 flex items-center justify-center z-10 absolute right-[15%] bottom-[15%] group-hover:scale-110 transition duration-500 shadow-sm"><span class="w-4 h-4 bg-emerald-400 rounded-full"></span></div>
             <div class="w-20 h-20 rounded-full bg-[var(--scheme-accent)]/5 flex items-center justify-center z-10 absolute group-hover:scale-110 transition border border-[var(--scheme-accent)]/20 duration-500 shadow-sm"><span class="w-8 h-8 bg-[var(--scheme-accent)] rounded-full shadow-glow-primary dark:shadow-[0_0_15px_rgba(167,139,250,0.5)]"></span></div>
          </div>
          <h3 class="typo-h3 transition-colors duration-300">Pre-trained on your specific problem class</h3>
       </div>
       
       <!-- Card 3 -->
       <div class="bg-[var(--scheme-shade)] rounded-[2rem] p-10 border border-[var(--scheme-border)] shadow-xl flex flex-col items-center text-center group overflow-hidden relative transition-colors duration-300 scheme-dark">
          <!-- decorative abstract grids -->
          <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.05]" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 20px 20px;"></div>
          <div class="w-full h-40 mb-8 flex items-center justify-center overflow-hidden gap-1.5 relative z-10">
             <!-- Tech grid mock -->
             <div class="w-8 h-12 bg-white/10 dark:bg-white/20 rounded-sm transform group-hover:-translate-y-2 transition duration-500"></div>
             <div class="w-8 h-20 bg-[var(--scheme-accent)] rounded-sm transform group-hover:translate-y-2 transition duration-500 shadow-[0_0_20px_rgba(90,50,250,0.6)] dark:shadow-[0_0_20px_rgba(167,139,250,0.4)]"></div>
             <div class="w-8 h-28 bg-white/10 dark:bg-white/20 rounded-sm transform group-hover:-translate-y-2 transition duration-500"></div>
             <div class="w-8 h-16 bg-emerald-500 rounded-sm transform group-hover:translate-y-2 transition duration-500 shadow-[0_0_20px_rgba(16,185,129,0.6)]"></div>
             <div class="w-8 h-10 bg-white/10 dark:bg-white/20 rounded-sm transform group-hover:-translate-y-2 transition duration-500"></div>
          </div>
          <h3 class="typo-h3 relative z-10">Unrivaled speed & performance at scale</h3>
       </div>
    </div>
  </div>
</section>
