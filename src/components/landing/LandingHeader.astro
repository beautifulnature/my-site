---
import { SITE_CONTENT } from "../../utils/siteContent";
import { TALK_TO_US_URL } from "../../utils/navigation";
import ThemeToggle from "../ThemeToggle.astro";

const RESOURCES_LINKS = [
  { href: "/blog", label: "Blog" },
  { href: "/resources/videos", label: "Videos" },
  { href: "/resources/stories", label: "Customer stories" },
  { href: "/resources/events", label: "Events" },
  { href: "/resources/press", label: "Press" },
  { href: "/resources/newsletter", label: "Newsletter" },
];

const pathname = Astro.url.pathname;

const isResourcesActive = pathname.startsWith("/blog") || pathname.startsWith("/resources");
const isDocsActive = pathname.startsWith("/docs");

const getDropdownItemClass = (href: string) => {
  const active = pathname === href || (href !== "/resources" && pathname.startsWith(href));
  return active ? "tf-dropdown-item is-active" : "tf-dropdown-item";
};

const getMobileSublinkClass = (href: string) => {
  const active = pathname === href || (href !== "/resources" && pathname.startsWith(href));
  return active ? "tf-mobile-sublink is-active" : "tf-mobile-sublink";
};
---

<header class="tf-header sticky top-0 z-50 bg-[var(--scheme-base)]/90 backdrop-blur-md border-b border-[var(--scheme-border)]">

  <div class="tf-header-inner flex items-center justify-between h-14 w-full gap-4 px-4 vp12:px-14 mx-auto" style="max-width: 1575px;">

    <a href="/" aria-label="Timefold home" class="flex items-center gap-2.5 shrink-0">
      <div class="h-8 w-8 rounded-lg bg-[#5A32FA] flex items-center justify-center">
        <svg
          class="w-[18px] h-[18px] text-white"
          viewBox="0 0 49.65 35"
          fill="currentColor"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M17.8038 9V0.5H8.5595V9H3.11566L0 17.5H8.5595V34.5H18.266C20.0635 34.5 21.6727 33.3814 22.2889 31.7052L24.1583 26.6018C24.1583 26.6018 24.3775 26.0034 25.0211 26.0034H38.5862L41.7019 17.5034H30.4889C28.6914 17.5034 27.0823 18.622 26.466 20.2982L24.5966 25.4016C24.5966 25.4016 24.3775 26 23.7338 26H17.8003V17.5H24.4939C26.2914 17.5 27.9005 16.3814 28.5168 14.7052L30.3862 9.6018C30.3862 9.6018 30.6053 9.0034 31.249 9.0034H46.526L49.6451 0.5H36.7202C34.9228 0.5 33.3136 1.6186 32.6973 3.2948L30.8279 8.3982C30.8279 8.3982 30.6088 8.9966 29.9651 8.9966H17.8003L17.8038 9Z"
          ></path>
        </svg>
      </div>
      <span class="text-[17px] font-bold tracking-tight text-[var(--scheme-title)]">Timefold</span>
    </a>

    <nav class="tf-desktop-nav items-center gap-0.5 flex-1 justify-center" aria-label="Desktop navigation">
      <a
        href="https://timefold.ai/solutions"
        target="_blank"
        rel="noopener noreferrer"
        class="tf-nav-link">Use cases</a
      >

      <div class="tf-dropdown-wrap">
        <a href="/resources" class={`tf-nav-link${isResourcesActive ? " is-active" : ""}`}>
          Resources
          <svg
            class="w-3.5 h-3.5 opacity-50 ml-0.5"
            fill="currentColor"
            viewBox="0 0 20 20"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
        <div class="tf-dropdown" role="menu">
          {
            RESOURCES_LINKS.map((item) => (
              <a href={item.href} class={getDropdownItemClass(item.href)} role="menuitem">
                {item.label}
              </a>
            ))
          }
        </div>
      </div>

      <a
        href="https://timefold.ai/pricing"
        target="_blank"
        rel="noopener noreferrer"
        class="tf-nav-link">Pricing</a
      >

      <a href="/docs" class={`tf-nav-link${isDocsActive ? " is-active" : ""}`}>Documentation</a>
    </nav>

    <div class="flex items-center gap-3 shrink-0">
      <ThemeToggle />
      <a
        href={TALK_TO_US_URL}
        class="tf-cta-btn tf-desktop-only"
        target="_blank"
        rel="noopener noreferrer">Talk to us</a
      >

      <button
        type="button"
        aria-label="Open menu"
        aria-controls="mobile-nav"
        aria-expanded="false"
        data-mobile-menu-button
        class="tf-hamburger-btn h-9 w-9 items-center justify-center rounded-md border border-[var(--scheme-border)] text-[var(--scheme-title)] transition hover:bg-[var(--scheme-surface)]"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-nav"
    class="hidden tf-mobile-drawer border-t border-[var(--scheme-border)] bg-[var(--scheme-base)]"
    data-mobile-nav
    aria-label="Mobile navigation"
  >
    <nav class="flex flex-col px-4 py-3 gap-1 mx-auto" style="max-width: 1575px;">
      <a
        href="https://timefold.ai/solutions"
        target="_blank"
        rel="noopener noreferrer"
        class="tf-mobile-link">Use cases</a
      >

      <div>
        <button
          type="button"
          class="tf-mobile-link w-full flex items-center justify-between"
          data-mobile-resources-toggle
          aria-expanded="false"
        >
          <span>Resources</span>
          <svg class="w-4 h-4 tf-mobile-chevron transition-transform" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
        <div class="hidden pl-4 pb-1 flex flex-col gap-0.5" data-mobile-resources-submenu>
          {
            RESOURCES_LINKS.map((item) => (
              <a href={item.href} class={getMobileSublinkClass(item.href)}>{item.label}</a>
            ))
          }
        </div>
      </div>

      <a
        href="https://timefold.ai/pricing"
        target="_blank"
        rel="noopener noreferrer"
        class="tf-mobile-link">Pricing</a
      >

      <a href="/docs" class="tf-mobile-link">Documentation</a>

      <div class="pt-2 border-t border-[var(--scheme-border)] mt-1">
        <a
          href={TALK_TO_US_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="tf-cta-btn block text-center w-full py-2.5"
        >
          {SITE_CONTENT.talkToUsLabel}
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  /* Responsive show/hide based on vp9 breakpoint (60em = 960px) */
  .tf-desktop-nav {
    display: none;
  }
  .tf-desktop-only {
    display: none !important;
  }
  .tf-hamburger-btn {
    display: inline-flex;
  }
  .tf-mobile-drawer {
    /* mobile nav is visible when toggled via JS (removes hidden class) */
  }
  @media (min-width: 60em) {
    .tf-desktop-nav {
      display: flex;
    }
    .tf-desktop-only {
      display: inline-flex !important;
    }
    .tf-hamburger-btn {
      display: none;
    }
    .tf-mobile-drawer {
      display: none !important;
    }
  }

  /* Define accent/title/base defaults on the header itself so they work on
     every page, even those without a scheme-* class on the body. */
  .tf-header {
    --tf-accent: var(--scheme-accent, #5A32FA);
    --tf-title:  var(--scheme-title,  #0f172a);
    --tf-base:   var(--scheme-base,   #ffffff);
    --tf-border: var(--scheme-border, rgba(0, 0, 0, 0.1));
    --tf-text:   var(--scheme-text,   #64748b);
  }
  html.dark .tf-header {
    --tf-accent: var(--scheme-accent, #7c5af6);
    --tf-title:  var(--scheme-title,  #f1f5f9);
    --tf-base:   var(--scheme-base,   #0b0f19);
    --tf-border: var(--scheme-border, rgba(255, 255, 255, 0.12));
    --tf-text:   var(--scheme-text,   #94a3b8);
  }

  .tf-nav-link {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    padding: 6px 14px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--tf-title);
    border-radius: 7px;
    text-decoration: none;
    transition:
      color 0.14s ease,
      background-color 0.14s ease;
    white-space: nowrap;
  }
  .tf-nav-link:hover {
    color: var(--tf-accent);
    background-color: rgba(90, 50, 250, 0.07);
  }
  .tf-nav-link.is-active {
    color: var(--tf-accent);
    background-color: rgba(90, 50, 250, 0.08);
  }

  .tf-dropdown-wrap {
    position: relative;
  }
  .tf-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 195px;
    background: var(--tf-base);
    border: 1px solid var(--tf-border);
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.13);
    padding: 6px;
    z-index: 200;
  }
  .tf-dropdown::before {
    content: "";
    position: absolute;
    top: -8px;
    left: 0;
    right: 0;
    height: 8px;
  }
  .tf-dropdown-wrap:hover .tf-dropdown,
  .tf-dropdown-wrap:focus-within .tf-dropdown {
    display: block;
  }
  .tf-dropdown-item {
    display: block;
    padding: 8px 14px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--tf-title);
    border-radius: 7px;
    text-decoration: none;
    transition:
      background-color 0.12s ease,
      color 0.12s ease;
  }
  .tf-dropdown-item:hover {
    background-color: var(--tf-accent);
    color: #ffffff;
  }
  .tf-dropdown-item.is-active {
    background-color: rgba(90, 50, 250, 0.1);
    color: var(--tf-accent);
    font-weight: 600;
  }
  .tf-dropdown-item.is-active:hover {
    background-color: var(--tf-accent);
    color: #ffffff;
  }

  .tf-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 7px 18px;
    font-size: 0.875rem;
    font-weight: 700;
    color: #ffffff;
    background-color: var(--tf-accent);
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.15s ease;
    white-space: nowrap;
  }
  .tf-cta-btn:hover {
    opacity: 0.88;
  }

  .tf-mobile-link {
    display: block;
    padding: 10px 12px;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--tf-title);
    border-radius: 8px;
    text-decoration: none;
    transition: background-color 0.12s ease;
  }
  .tf-mobile-link:hover {
    background-color: rgba(90, 50, 250, 0.07);
  }
  .tf-mobile-sublink {
    display: block;
    padding: 8px 12px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--tf-text);
    border-radius: 7px;
    text-decoration: none;
    transition: background-color 0.12s ease;
  }
  .tf-mobile-sublink:hover {
    background-color: rgba(90, 50, 250, 0.07);
    color: var(--tf-accent);
  }
  .tf-mobile-sublink.is-active {
    color: var(--tf-accent);
    font-weight: 600;
    background-color: rgba(90, 50, 250, 0.07);
  }
</style>

<script is:inline src="/mobile-menu.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var toggle = document.querySelector('[data-mobile-resources-toggle]');
    var submenu = document.querySelector('[data-mobile-resources-submenu]');
    var chevron = document.querySelector('.tf-mobile-chevron');
    if (toggle && submenu) {
      toggle.addEventListener('click', function () {
        var isOpen = !submenu.classList.contains('hidden');
        submenu.classList.toggle('hidden');
        toggle.setAttribute('aria-expanded', String(!isOpen));
        if (chevron) chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
      });
    }
  });
</script>
