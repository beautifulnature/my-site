---
import ThemeToggle from "../ThemeToggle.astro";
import { TALK_TO_US_URL } from "../../utils/navigation";

const RESOURCES_LINKS = [
  { href: "/blog", label: "Blog" },
  { href: "/resources/videos", label: "Videos" },
  { href: "/resources/stories", label: "Customer stories" },
  { href: "/resources/events", label: "Events" },
  { href: "/resources/press", label: "Press" },
  { href: "/resources/newsletter", label: "Newsletter" },
];
---

<header class="tf-header sticky top-0 z-50 vp12:layout vp12:bound-x px-4 vp12:px-14 bg-[var(--scheme-base)]/90 backdrop-blur-md border-b border-[var(--scheme-border)]">
  <div class="flex items-center justify-between h-14 w-full gap-4">

    <a href="/" aria-label="Timefold home" class="flex items-center gap-2.5 shrink-0">
      <div class="h-8 w-8 rounded-lg bg-[#5A32FA] flex items-center justify-center">
        <svg class="w-[18px] h-[18px] text-white" viewBox="0 0 49.65 35" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M17.8038 9V0.5H8.5595V9H3.11566L0 17.5H8.5595V34.5H18.266C20.0635 34.5 21.6727 33.3814 22.2889 31.7052L24.1583 26.6018C24.1583 26.6018 24.3775 26.0034 25.0211 26.0034H38.5862L41.7019 17.5034H30.4889C28.6914 17.5034 27.0823 18.622 26.466 20.2982L24.5966 25.4016C24.5966 25.4016 24.3775 26 23.7338 26H17.8003V17.5H24.4939C26.2914 17.5 27.9005 16.3814 28.5168 14.7052L30.3862 9.6018C30.3862 9.6018 30.6053 9.0034 31.249 9.0034H46.526L49.6451 0.5H36.7202C34.9228 0.5 33.3136 1.6186 32.6973 3.2948L30.8279 8.3982C30.8279 8.3982 30.6088 8.9966 29.9651 8.9966H17.8003L17.8038 9Z"/>
        </svg>
      </div>
      <span class="text-[17px] font-bold tracking-tight text-[var(--scheme-title)]">Timefold</span>
    </a>

    <nav class="flex items-center gap-0.5 flex-1 justify-center">
      <a
        href="https://timefold.ai/solutions"
        target="_blank"
        rel="noopener noreferrer"
        class="tf-nav-link"
      >Use cases</a>

      <div class="tf-dropdown-wrap">
        <a href="/resources" class="tf-nav-link">
          Resources
          <svg class="w-3.5 h-3.5 opacity-50 ml-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
        </a>
        <div class="tf-dropdown" role="menu">
          {RESOURCES_LINKS.map((item) => (
            <a href={item.href} class="tf-dropdown-item" role="menuitem">{item.label}</a>
          ))}
        </div>
      </div>

      <a
        href="https://timefold.ai/pricing"
        target="_blank"
        rel="noopener noreferrer"
        class="tf-nav-link"
      >Pricing</a>

      <a href="/docs" class="tf-nav-link">Documentation</a>
    </nav>

    <div class="flex items-center gap-3 shrink-0">
      <ThemeToggle />
      <a
        href={TALK_TO_US_URL}
        class="tf-cta-btn"
        target="_blank"
        rel="noopener noreferrer"
      >Talk to us</a>
    </div>
  </div>
</header>

<style>
  .tf-nav-link {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    padding: 6px 14px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--scheme-title);
    border-radius: 7px;
    text-decoration: none;
    transition: color 0.14s ease, background-color 0.14s ease;
    white-space: nowrap;
  }
  .tf-nav-link:hover {
    color: var(--scheme-accent);
    background-color: rgba(90, 50, 250, 0.07);
  }

  .tf-dropdown-wrap {
    position: relative;
  }
  .tf-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 195px;
    background: var(--scheme-base);
    border: 1px solid var(--scheme-border, rgba(0,0,0,0.1));
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.13);
    padding: 6px;
    z-index: 200;
  }
  .tf-dropdown::before {
    content: "";
    position: absolute;
    top: -8px;
    left: 0;
    right: 0;
    height: 8px;
  }
  .tf-dropdown-wrap:hover .tf-dropdown,
  .tf-dropdown-wrap:focus-within .tf-dropdown {
    display: block;
  }
  .tf-dropdown-item {
    display: block;
    padding: 8px 14px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--scheme-title);
    border-radius: 7px;
    text-decoration: none;
    transition: background-color 0.12s ease, color 0.12s ease;
  }
  .tf-dropdown-item:hover {
    background-color: var(--scheme-accent);
    color: #ffffff;
  }

  .tf-cta-btn {
    display: inline-flex;
    align-items: center;
    padding: 7px 18px;
    font-size: 0.875rem;
    font-weight: 700;
    color: #ffffff;
    background-color: var(--scheme-accent);
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.15s ease;
    white-space: nowrap;
  }
  .tf-cta-btn:hover {
    opacity: 0.88;
  }
</style>
