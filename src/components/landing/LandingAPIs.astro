---
---
<section class="bg-white dark:bg-[#0b0f19] layout bound-x py-[32px] m-0 border-0 relative z-10 transition-colors duration-300 scheme-default">
  <div class="w-full h-full">
    <div class="bg-[#0b0f19] dark:bg-[#0f1523] rounded-[3rem] p-12 lg:p-24 text-center shadow-2xl border border-transparent dark:border-white/5 overflow-hidden relative transition-colors duration-300 scheme-dark">
      <!-- Decorational glow elements -->
      <div class="absolute top-0 right-0 w-64 h-64 bg-emerald-500/10 dark:bg-emerald-500/20 rounded-full blur-[80px]"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-purple-500/10 dark:bg-purple-500/20 rounded-full blur-[100px]"></div>
      
      <div class="relative z-10 max-w-screen-vp10 mx-auto text-center">
         <h2 class="typo-h2 mb-6">
           Real-world and ready-to-use <span class="text-[var(--scheme-accent)]">APIs</span>
         </h2>
         <p class="typo-p mb-20 max-w-2xl mx-auto opacity-80">
           Built specifically for your domain and scaled automatically.
         </p>
         
         <div class="flex flex-wrap justify-center">
           <div class="w-full vp7:w-1/3 flex flex-col items-center text-center group cursor-pointer px-4">
             <div class="h-28 w-28 mb-8 relative transition transform group-hover:-translate-y-2 duration-300">
                <svg class="text-emerald-500 w-full h-full drop-shadow-[0_0_20px_rgba(16,185,129,0.3)] dark:drop-shadow-[0_0_20px_rgba(16,185,129,0.5)]" viewBox="0 0 100 100" fill="currentColor">
                   <polygon points="50,5 95,25 95,75 50,95 5,75 5,25"/>
                   <circle cx="50" cy="50" r="20" fill="#fff" fill-opacity="0.2"/>
                </svg>
             </div>
             <h3 class="typo-h3 mb-3">Field Service Routing</h3>
             <p class="typo-p opacity-80">Plan hundreds of unpredictable jobs for field technicians.</p>
           </div>
           
           <div class="w-full vp7:w-1/3 flex flex-col items-center text-center group cursor-pointer px-4">
             <div class="h-28 w-28 mb-8 relative transition transform group-hover:-translate-y-2 duration-300">
                <svg class="text-orange-500 w-full h-full drop-shadow-[0_0_20px_rgba(249,115,22,0.3)] dark:drop-shadow-[0_0_20px_rgba(249,115,22,0.5)]" viewBox="0 0 100 100" fill="currentColor">
                   <polygon points="50,5 95,25 95,75 50,95 5,75 5,25"/>
                   <circle cx="50" cy="50" r="20" fill="#fff" fill-opacity="0.2"/>
                </svg>
             </div>
             <h3 class="typo-h3 mb-3">Shift Scheduling</h3>
             <p class="typo-p opacity-80">Match shifts and requirements automatically.</p>
           </div>
           
           <div class="w-full vp7:w-1/3 flex flex-col items-center text-center group cursor-pointer px-4">
              <div class="h-28 w-28 mb-8 relative transition transform group-hover:-translate-y-2 duration-300">
                <svg class="text-rose-500 w-full h-full drop-shadow-[0_0_20px_rgba(244,63,94,0.3)] dark:drop-shadow-[0_0_20px_rgba(244,63,94,0.5)]" viewBox="0 0 100 100" fill="currentColor">
                   <polygon points="50,5 95,25 95,75 50,95 5,75 5,25"/>
                   <circle cx="50" cy="50" r="20" fill="#fff" fill-opacity="0.2"/>
                </svg>
             </div>
             <h3 class="typo-h3 mb-3">Delivery Routing</h3>
             <p class="typo-p opacity-80">Consolidate orders perfectly into efficient truck routes.</p>
           </div>
         </div>
         
         <div class="mt-20">
            <a href="#" class="px-8 py-4 text-white hover:text-white border border-slate-700 dark:border-slate-600 hover:border-slate-500 bg-white/5 hover:bg-white/10 transition-colors rounded-full font-bold shadow-lg">View all models</a>
         </div>
      </div>
    </div>
  </div>
</section>
