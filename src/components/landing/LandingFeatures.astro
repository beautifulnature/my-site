---
---
<section class="bg-white dark:bg-[#0b0f19] layout bound-x py-[32px] m-0 border-0 overflow-hidden transition-colors duration-300 scheme-default">
  <div class="w-full h-full space-y-32">
    <!-- Feature 1 -->
    <div class="flex flex-col md:flex-row items-center gap-12 lg:gap-20">
      <div class="flex-1 md:order-2">
         <h2 class="typo-h2 mb-6 transition-colors">Auto-generate large-scale <span class="text-[var(--scheme-accent)]">schedules</span></h2>
         <p class="typo-p mb-8 max-w-lg transition-colors">
           Solve even the most intricate scheduling problems dynamically and securely inside your private cloud. Give planners a reliable foundation to work with.
         </p>
      </div>
      <div class="flex-1 md:order-1 relative w-full h-[400px] sm:h-[480px] bg-[var(--scheme-shade)] rounded-[3rem] border border-[var(--scheme-border)] overflow-hidden flex items-center justify-center shadow-lg dark:shadow-none transition-colors duration-300 group">
         <!-- Abstract Graphic Mock -->
         <div class="absolute w-64 h-64 bg-white/60 dark:bg-[#0b0f19]/60 backdrop-blur rounded-2xl transform rotate-12 border border-white dark:border-white/10 shadow-md dark:shadow-[0_0_15px_rgba(255,255,255,0.05)] group-hover:rotate-6 transition duration-700"></div>
         <div class="absolute w-56 h-32 bg-white dark:bg-[#111827] rounded-xl transform -translate-x-12 -translate-y-8 shadow-xl border border-gray-100 dark:border-white/10 p-5 group-hover:-translate-y-12 transition duration-700">
             <div class="w-1/2 h-3 bg-gray-200 dark:bg-slate-700 rounded-full mb-5 transition-colors"></div>
             <div class="w-3/4 h-2.5 bg-gray-100 dark:bg-slate-800 rounded-full mb-3 transition-colors"></div>
             <div class="w-2/3 h-2.5 bg-gray-100 dark:bg-slate-800 rounded-full transition-colors"></div>
         </div>
      </div>
    </div>
    
    <!-- Feature 2 -->
    <div class="flex flex-col md:flex-row items-center gap-12 lg:gap-20">
      <div class="flex-1">
         <h2 class="typo-h2 mb-6 transition-colors"><span class="text-[var(--scheme-accent)]">Always-on</span> operations</h2>
         <p class="typo-p mb-8 max-w-lg transition-colors">
           Ensure continuous service reliability by deploying on auto-scaling infrastructure. Optimize over long planning horizons gracefully and effortlessly.
         </p>
      </div>
      <div class="flex-1 relative w-full h-[400px] sm:h-[480px] bg-slate-50 dark:bg-white/[0.02] rounded-[3rem] border border-gray-200 dark:border-white/5 overflow-hidden flex items-center justify-center shadow-lg dark:shadow-none transition-colors duration-300 group">
         <div class="w-64 h-64 rounded-full border-[24px] border-[#5A32FA]/10 dark:border-[#a78bfa]/10 flex items-center justify-center group-hover:scale-110 transition duration-700">
            <div class="w-40 h-40 rounded-full border-[20px] border-[#5A32FA] dark:border-[#a78bfa] shadow-glow-primary dark:shadow-[0_0_30px_rgba(167,139,250,0.4)]"></div>
         </div>
      </div>
    </div>
    
    <!-- Feature 3 -->
    <div class="flex flex-col md:flex-row items-center gap-12 lg:gap-20">
      <div class="flex-1 md:order-2">
         <h2 class="typo-h2 mb-6 transition-colors">Beat day-to-day <span class="text-[var(--scheme-accent)]">chaos</span></h2>
         <p class="typo-p mb-8 max-w-lg transition-colors">
           React to disruptions like cancellations, traffic, or sickness dynamically without compromising the overarching goal logic. Keep vehicles moving.
         </p>
      </div>
      <div class="flex-1 md:order-1 relative w-full h-[400px] sm:h-[480px] bg-slate-50 dark:bg-white/[0.02] rounded-[3rem] border border-gray-200 dark:border-white/5 overflow-hidden shadow-lg dark:shadow-none p-8 sm:p-12 flex flex-col justify-end transition-colors duration-300 group">
          <div class="w-full bg-white dark:bg-[#111827] h-20 rounded-2xl shadow-md border border-gray-100 dark:border-white/10 mb-6 flex items-center px-6 gap-6 transform group-hover:-translate-y-4 transition-all duration-500 relative z-20">
              <div class="w-10 h-10 rounded-full bg-[#5A32FA]/10 dark:bg-[#a78bfa]/20 flex items-center justify-center text-[#5A32FA] dark:text-[#a78bfa] font-bold">!</div>
              <div class="h-3 bg-gray-200 dark:bg-slate-700 rounded-full w-1/3 transition-colors"></div>
          </div>
          <div class="w-full bg-white dark:bg-[#111827] h-20 rounded-2xl shadow-sm border border-gray-100 dark:border-white/10 flex items-center px-6 gap-6 opacity-60 dark:opacity-40 transform group-hover:translate-y-2 transition-all duration-500">
              <div class="w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-800 transition-colors"></div>
              <div class="h-3 bg-gray-100 dark:bg-slate-800 rounded-full w-1/2 transition-colors"></div>
          </div>
          <!-- Decorative background blur -->
          <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-[#5A32FA] dark:bg-[#a78bfa] rounded-full blur-[80px] opacity-20 dark:opacity-10 pointer-events-none"></div>
      </div>
    </div>
    
    <!-- Feature 4 -->
    <div class="flex flex-col md:flex-row items-center gap-12 lg:gap-20">
      <div class="flex-1">
         <h2 class="typo-h2 mb-6 transition-colors">Balanced workdays, <span class="text-[var(--scheme-accent)]">happy workforces</span></h2>
         <p class="typo-p mb-8 max-w-lg transition-colors">
           Promote employee retention by giving shifts and task assignments that respect personal preferences, limits, and union rules.
         </p>
      </div>
      <div class="flex-1 relative w-full h-[400px] sm:h-[480px] bg-slate-50 dark:bg-white/[0.02] rounded-[3rem] border border-gray-200 dark:border-white/5 overflow-hidden shadow-lg dark:shadow-none flex items-center justify-center transition-colors duration-300 group">
         <div class="flex gap-4 items-end h-64 w-full px-16 justify-center">
            <div class="w-16 bg-gray-200 dark:bg-slate-700 rounded-t-xl h-[40%] group-hover:h-[50%] transition-all duration-700"></div>
            <div class="w-16 bg-[#5A32FA] dark:bg-[#a78bfa] rounded-t-xl h-[80%] group-hover:h-[60%] transition-all duration-700 shadow-xl dark:shadow-[0_0_15px_rgba(167,139,250,0.3)]"></div>
            <div class="w-16 bg-gray-200 dark:bg-slate-700 rounded-t-xl h-[100%] group-hover:h-[70%] transition-all duration-700"></div>
            <div class="w-16 bg-[#5A32FA] dark:bg-[#a78bfa] rounded-t-xl h-[60%] group-hover:h-[90%] transition-all duration-700 shadow-xl dark:shadow-[0_0_15px_rgba(167,139,250,0.3)]"></div>
         </div>
      </div>
    </div>
  </div>
</section>
