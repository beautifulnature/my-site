---
---
<section class="bg-white dark:bg-[#0b0f19] layout bound-x py-[32px] m-0 border-0 transition-colors duration-300 scheme-default">
  <div class="w-full h-full">
    <div class="bg-[#5A32FA] dark:bg-[#4a26d9] rounded-[3rem] p-10 lg:p-16 text-center shadow-[0_30px_60px_-15px_rgba(90,50,250,0.5)] dark:shadow-[0_20px_50px_-10px_rgba(0,0,0,0.7)] relative overflow-hidden transition-colors duration-300 scheme-purple">
      <!-- Decorative background glow -->
      <div class="absolute inset-0 bg-gradient-to-br from-[#774bfc] to-[#3a1da3] dark:from-[#5b32cd] dark:to-[#27107c] pointer-events-none transition-colors duration-300"></div>
      <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-white/5 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/3"></div>
      
      <div class="relative z-10">
        <span class="typo-label opacity-80 mb-4 block transition-colors">Uncover hidden graph patterns</span>
        <h2 class="typo-h1 mb-16 drop-shadow-md">
          Timefold Intelligence
        </h2>
        
        <!-- Mock Dashboard Container -->
        <div class="bg-white/10 dark:bg-black/20 backdrop-blur-xl border border-white/20 dark:border-white/10 rounded-[2rem] p-4 md:p-6 shadow-2xl transition-colors duration-300">
           
           <div class="flex flex-wrap gap-4 mb-6">
              <div class="bg-white dark:bg-[#0b0f19] rounded-xl flex-1 h-14 flex items-center px-6 shadow-md text-sm font-bold text-gray-800 dark:text-slate-200 border border-transparent dark:border-white/5 transition-colors">Model: Route Assignment</div>
              <div class="bg-white dark:bg-[#0b0f19] rounded-xl flex-1 h-14 flex items-center px-6 shadow-md text-sm font-bold text-gray-800 dark:text-slate-200 border border-transparent dark:border-white/5 transition-colors">Time: Real-time API</div>
              <div class="bg-white dark:bg-[#0b0f19] rounded-xl flex-1 h-14 flex items-center px-6 shadow-md text-sm font-bold text-gray-800 dark:text-slate-200 border border-transparent dark:border-white/5 transition-colors">SLA: 99.9% targeted</div>
           </div>
           
           <div class="grid lg:grid-cols-3 gap-6">
              <!-- Map Mock -->
              <div class="bg-white dark:bg-[#0b0f19] rounded-2xl shadow-md h-72 md:h-96 border border-gray-100 dark:border-white/5 flex items-center justify-center col-span-1 p-2 relative overflow-hidden transition-colors">
                 <div class="absolute inset-0 opacity-[0.05] dark:opacity-[0.1]" style="background-image: radial-gradient(currentcolor 1px, transparent 1px); background-size: 24px 24px; color: inherit;"></div>
                 <svg viewBox="0 0 100 100" class="w-full h-full text-gray-200 dark:text-slate-800 stroke-current relative z-10 transition-colors" fill="none">
                    <path d="M10,90 Q30,10 90,50" stroke-width="2"/>
                    <path d="M10,10 L50,50 L90,10" stroke-width="2"/>
                    <circle cx="50" cy="50" r="5" fill="#5A32FA" class="dark:fill-[#a78bfa]"/>
                    <circle cx="10" cy="90" r="4" fill="#10b981"/>
                    <circle cx="90" cy="50" r="4" fill="#ef4444"/>
                    <circle cx="10" cy="10" r="3" fill="#f59e0b"/>
                 </svg>
              </div>
              
              <div class="col-span-1 lg:col-span-2 flex flex-col gap-6">
                <!-- Schedule Mock -->
                <div class="bg-white dark:bg-[#0b0f19] rounded-2xl shadow-md h-full min-h-[160px] border border-gray-100 dark:border-white/5 flex p-6 gap-4 overflow-hidden transition-colors">
                   <div class="w-16 h-full flex flex-col justify-between text-xs text-gray-400 dark:text-slate-500 font-mono font-bold py-2 transition-colors"><p>V1</p><p>V2</p><p>V3</p></div>
                   <div class="flex-1 border-l-2 border-dashed border-gray-100 dark:border-slate-800 relative pl-4 h-full flex flex-col gap-4 justify-center transition-colors">
                      <div class="w-[85%] h-8 bg-indigo-50 dark:bg-indigo-900/30 border border-indigo-100 dark:border-indigo-800/50 rounded-lg shadow-inner transition-colors"></div>
                      <div class="w-[65%] h-8 bg-emerald-50 dark:bg-emerald-900/30 border border-emerald-100 dark:border-emerald-800/50 rounded-lg shadow-inner ml-8 transition-colors"></div>
                      <div class="w-[95%] h-8 bg-[#5A32FA]/10 dark:bg-[#a78bfa]/10 border border-[#5A32FA]/20 dark:border-[#a78bfa]/20 rounded-lg shadow-inner transition-colors"></div>
                   </div>
                </div>
                
                <!-- Metrics Mock -->
                <div class="grid grid-cols-3 gap-6 h-full min-h-[140px]">
                   <div class="bg-white dark:bg-[#0b0f19] rounded-2xl shadow-md border border-gray-100 dark:border-white/5 p-6 text-center flex flex-col justify-center transition-colors">
                     <span class="text-gray-400 dark:text-slate-500 text-xs uppercase font-bold mb-2 block tracking-wider transition-colors">Vehicles</span>
                     <span class="text-4xl font-extrabold text-[#5A32FA] dark:text-[#a78bfa] transition-colors">150</span>
                   </div>
                   <div class="bg-white dark:bg-[#0b0f19] rounded-2xl shadow-md border border-gray-100 dark:border-white/5 p-6 text-center flex flex-col justify-center transition-colors">
                     <span class="text-gray-400 dark:text-slate-500 text-xs uppercase font-bold mb-2 block tracking-wider transition-colors">Tasks</span>
                     <span class="text-4xl font-extrabold text-[#5A32FA] dark:text-[#a78bfa] transition-colors">2.4K</span>
                   </div>
                   <div class="bg-white dark:bg-[#0b0f19] rounded-2xl shadow-md border border-gray-100 dark:border-white/5 p-6 text-center flex items-center justify-center relative overflow-hidden transition-colors">
                     <div class="w-20 h-20 rounded-full border-[6px] border-[#10b981] border-r-transparent dark:border-r-transparent transform rotate-45 flex items-center justify-center">
                        <span class="transform -rotate-45 text-gray-800 dark:text-slate-200 font-bold transition-colors">99%</span>
                     </div>
                   </div>
                </div>
              </div>
           </div>
        </div>
      </div>
    </div>
  </div>
</section>
