<style is:global>
  @import 'aos/dist/aos.css';
</style>

<script>
  import AOS from 'aos';

  function initAOS() {
    AOS.init({
      duration: 700,
      easing: 'ease-out-quad',
      once: true,
      offset: 60,
      delay: 0,
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAOS);
  } else {
    initAOS();
  }

  document.addEventListener('astro:page-load', initAOS);
</script>
