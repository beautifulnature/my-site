---
import type { GetStaticPaths } from 'astro';
import DocsLayout from '../../../layouts/Docs.astro';
import ResourceDetailArticle from '../../../components/ResourceDetailArticle.astro';
import MoreItemsGrid from '../../../components/MoreItemsGrid.astro';
import MoreItemCard from '../../../components/MoreItemCard.astro';
import {
  buildMoreItemCardProps,
  buildDetailPageMetaFromCollection,
  buildStaticPathsFromCollection,
} from '../../../utils/content';
import type { VideoEntry } from '../../../types/collections';
import { RESOURCE_TYPES } from '../../../utils/resourceTypes';

export const getStaticPaths: GetStaticPaths = async () => {
  return buildStaticPathsFromCollection('videos', 'video');
};

const { video } = Astro.props as { video: VideoEntry };
const { Content } = await video.render();
const resourceType = RESOURCE_TYPES.videos;

const {
  pageUrl,
  moreItems: moreVideos,
  tags: videoTags,
} = await buildDetailPageMetaFromCollection('videos', video, resourceType.detailBasePath, Astro.request?.url, 3);
---

<DocsLayout>
  <ResourceDetailArticle
    backHref={resourceType.backHref}
    backLabel={resourceType.backLabel}
    iconName={resourceType.iconName}
    pageUrl={pageUrl}
    shareTitle={video.data.title}
  >
    <Fragment slot="header">
      <div class="c-hero__content">
        <h1 class="c-title c-hero__title">{video.data.title}</h1>
      </div>
    </Fragment>

    <Fragment slot="author">
      <span class="c-metadata__date">{video.data.date.toLocaleDateString()}</span>
      {video.data.length && (
        <>
          <span class="c-metadata__dot" />
          <span>{video.data.length}</span>
        </>
      )}
    </Fragment>

    <Fragment slot="tags">
      {videoTags.length > 0 && (
        <span class="flex flex-wrap gap-1 mt-1">
          {videoTags.map((tag) => (
            <a
              href={`${resourceType.tagBasePath}/${encodeURIComponent(tag)}`}
              class="c-label c-label--small c-label--light-grey c-label--lower c-label--filter"
            >{tag}</a>
          ))}
        </span>
      )}
    </Fragment>

    <Fragment slot="content">
      {video.data.youtubeId && (
        <div class="mb-6 overflow-hidden rounded-xl border border-slate-200 bg-slate-50">
          <div class="aspect-video">
            <iframe
              class="h-full w-full"
              src={`https://www.youtube.com/embed/${video.data.youtubeId}`}
              title={video.data.title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            />
          </div>
        </div>
      )}
      <Content />
    </Fragment>
  </ResourceDetailArticle>

  {moreVideos.length > 0 && (
    <MoreItemsGrid title={resourceType.moreTitle} gridId="more-videos-grid">
      {moreVideos.map((v) => (
        <MoreItemCard {...buildMoreItemCardProps(v, resourceType.detailBasePath, resourceType.moreCard)} />
      ))}
    </MoreItemsGrid>
  )}
</DocsLayout>
