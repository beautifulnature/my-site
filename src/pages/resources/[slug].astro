---
import type { GetStaticPaths } from 'astro';
import DocsLayout from '../../layouts/Docs.astro';
import ResourceDetailArticle from '../../components/ResourceDetailArticle.astro';
import MoreItemsGrid from '../../components/MoreItemsGrid.astro';
import MoreItemCard from '../../components/MoreItemCard.astro';
import {
  buildMoreItemCardProps,
  buildDetailPageMetaFromCollection,
  buildStaticPathsFromCollection,
} from '../../utils/content';
import { RESOURCE_TYPES } from '../../utils/resourceTypes';
import type { EventEntry, NewsletterEntry, PressEntry, StoryEntry } from '../../types/collections';

const resourceMap = {
  events: {
    type: 'events',
    entryKey: 'event',
    entryType: 'EventEntry',
    resourceType: RESOURCE_TYPES.events,
    getStaticPaths: () => buildStaticPathsFromCollection('events', 'event'),
  },
  newsletter: {
    type: 'newsletter',
    entryKey: 'issue',
    entryType: 'NewsletterEntry',
    resourceType: RESOURCE_TYPES.newsletter,
    getStaticPaths: () => buildStaticPathsFromCollection('newsletter', 'issue'),
  },
  press: {
    type: 'press',
    entryKey: 'item',
    entryType: 'PressEntry',
    resourceType: RESOURCE_TYPES.press,
    getStaticPaths: () => buildStaticPathsFromCollection('press', 'item'),
  },
  stories: {
    type: 'stories',
    entryKey: 'story',
    entryType: 'StoryEntry',
    resourceType: RESOURCE_TYPES.stories,
    getStaticPaths: () => buildStaticPathsFromCollection('stories', 'story'),
  },
};

export const getStaticPaths: GetStaticPaths = async () => {
  // Aggregate all static paths from all resource types
  const allPaths: any[] = [];
  (Object.keys(resourceMap) as Array<keyof typeof resourceMap>).forEach(async (key) => {
    const paths = await resourceMap[key].getStaticPaths();
    allPaths.push(...paths.map((p: any) => ({ ...p, params: { ...p.params, resourceType: key } })));
  });
  // Wait for all async operations to finish
  const resolvedPaths = await Promise.all(
    (Object.keys(resourceMap) as Array<keyof typeof resourceMap>).map(async (key) => {
      const paths = await resourceMap[key].getStaticPaths();
      return paths.map((p: any) => ({ ...p, params: { ...p.params, resourceType: key } }));
    })
  );
  return resolvedPaths.flat();
};

const { resourceType, ...props } = Astro.props;
const config = resourceMap[resourceType as keyof typeof resourceMap];

let entry: any = undefined;
let Content: any = undefined;
let meta: any = undefined;
if (resourceType === 'events' && props.event) {
  entry = props.event as EventEntry;
  Content = (await entry.render()).default;
  meta = await buildDetailPageMetaFromCollection('events', entry, config.resourceType.detailBasePath, Astro.request?.url, 3);
} else if (resourceType === 'newsletter' && props.issue) {
  entry = props.issue as NewsletterEntry;
  Content = (await entry.render()).default;
  meta = await buildDetailPageMetaFromCollection('newsletter', entry, config.resourceType.detailBasePath, Astro.request?.url, 3);
} else if (resourceType === 'press' && props.item) {
  entry = props.item as PressEntry;
  Content = (await entry.render()).default;
  meta = await buildDetailPageMetaFromCollection('press', entry, config.resourceType.detailBasePath, Astro.request?.url, 3);
} else if (resourceType === 'stories' && props.story) {
  entry = props.story as StoryEntry;
  Content = (await entry.render()).default;
  meta = await buildDetailPageMetaFromCollection('stories', entry, config.resourceType.detailBasePath, Astro.request?.url, 3);
}
---

<DocsLayout enableToc={resourceType === 'newsletter'}>
  {entry && meta && Content && (
    <ResourceDetailArticle
      backHref={config.resourceType.backHref}
      backLabel={config.resourceType.backLabel}
      iconName={config.resourceType.iconName}
      pageUrl={meta.pageUrl}
      shareTitle={entry.data.title}
      articleClass="prose blog-prose text-slate-900"
      metaRowClass={resourceType === 'stories' ? 'text-xs text-slate-900' : resourceType === 'events' ? 'text-xs text-black' : resourceType === 'press' ? 'text-black' : ''}
      articleId={resourceType === 'newsletter' ? 'article-root' : undefined}
    >
      <Fragment slot="meta">
        {resourceType === 'events' && (
          <>
            <span>{entry.data.date.toLocaleDateString()}</span>
            {entry.data.location && (<><span class="h-1 w-1 rounded-full bg-slate-600" /><span>{entry.data.location}</span></>)}
            {entry.data.url && (<><span class="h-1 w-1 rounded-full bg-slate-600" /><a href={entry.data.url} target="_blank" rel="noreferrer" class="underline hover:text-[var(--scheme-accent)]">Registration</a></>)}
          </>
        )}
        {resourceType === 'newsletter' && (
          <span>{entry.data.date.toLocaleDateString()}{entry.data.issue ? ` · ${entry.data.issue}` : ''}</span>
        )}
        {resourceType === 'press' && (
          <>
            <span>{entry.data.date.toLocaleDateString()}</span>
            <span class="h-1 w-1 rounded-full" />
            <span>{entry.data.outlet}</span>
          </>
        )}
        {resourceType === 'stories' && (
          <div class="flex flex-col gap-1">
            <p class="text-xs">{entry.data.date.toLocaleDateString()}{entry.data.industry ? ` · ${entry.data.industry}` : ''}</p>
            <p class="text-sm">{entry.data.customer}</p>
          </div>
        )}
        {/* Tags for all types */}
        {meta.tags && meta.tags.length > 0 && (
          <span class="flex flex-wrap gap-1 mt-1">
            {meta.tags.map((tag: string) => (
              <span class="tag-chip text-[10px]">{tag}</span>
            ))}
          </span>
        )}
      </Fragment>
      <Content />
    </ResourceDetailArticle>
  )}
  {/* More items for each type */}
  {meta && meta.moreItems && meta.moreItems.length > 0 && (
    <MoreItemsGrid title={config.resourceType.moreTitle}>
      {meta.moreItems.map((item: any) => (
        <MoreItemCard {...buildMoreItemCardProps(item, config.resourceType.detailBasePath, config.resourceType.moreCard)} />
      ))}
    </MoreItemsGrid>
  )}
</DocsLayout>
