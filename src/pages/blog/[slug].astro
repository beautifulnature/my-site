---
import type { GetStaticPaths } from "astro";
import DocsLayout from "../../layouts/Docs.astro";
import ResourceDetailArticle from "../../components/ResourceDetailArticle.astro";
import MoreItemsGrid from "../../components/MoreItemsGrid.astro";
import MoreItemCard from "../../components/MoreItemCard.astro";
import {
  buildMoreItemCardProps,
  buildDetailPageMetaFromCollection,
  buildStaticPathsFromCollection,
} from "../../utils/content";
import type { BlogEntry } from "../../types/collections";
import { RESOURCE_TYPES } from "../../utils/resourceTypes";

export const getStaticPaths: GetStaticPaths = async () => {
  return buildStaticPathsFromCollection("blog", "post");
};

const { post } = Astro.props as { post: BlogEntry };
const { Content } = await post.render();
const resourceType = RESOURCE_TYPES.blog;

const {
  pageUrl,
  moreItems: morePosts,
  tags: postTags,
} = await buildDetailPageMetaFromCollection(
  "blog",
  post,
  resourceType.detailBasePath,
  Astro.request?.url,
  3,
);

const BLOG_HERO_SRC =
  "https://timefold.ai/uploads/images/blog/2025/_1200x514_crop_center-center_90_none/22855/planning-problems-are-everywhere.webp";
const BLOG_HERO_SRCSET = [
  "https://timefold.ai/uploads/images/blog/2025/_1200x514_crop_center-center_90_none/22855/planning-problems-are-everywhere.webp 1200w",
  "https://timefold.ai/uploads/images/blog/2025/_992x425_crop_center-center_90_none/22855/planning-problems-are-everywhere.webp 992w",
  "https://timefold.ai/uploads/images/blog/2025/_720x309_crop_center-center_90_none/22855/planning-problems-are-everywhere.webp 720w",
  "https://timefold.ai/uploads/images/blog/2025/_480x206_crop_center-center_90_none/22855/planning-problems-are-everywhere.webp 480w",
  "https://timefold.ai/uploads/images/blog/2025/_320x137_crop_center-center_90_none/22855/planning-problems-are-everywhere.webp 320w",
].join(", ");
---

<DocsLayout enableToc={true}>
  <ResourceDetailArticle
    backHref={resourceType.backHref}
    backLabel={resourceType.backLabel}
    iconName={resourceType.iconName}
    pageUrl={pageUrl}
    shareTitle={post.data.title}
    articleClass="prose blog-prose"
    articleId="article-root"
    heroImageSrc={BLOG_HERO_SRC}
    heroImageSrcSet={BLOG_HERO_SRCSET}
  >
    <Fragment slot="header">
      <div class="c-hero__content">
        <h1 class="c-title c-hero__title">{post.data.title}</h1>
        {post.data.description && (
          <div class="c-text s-wysiwyg c-hero__text s-wysiwyg--big">
            <p>{post.data.description}</p>
          </div>
        )}
      </div>
      <div class="c-hero__graphic">
        <svg
          class="c-hero__graphic-asset"
          width="1364"
          height="750"
          viewBox="0 0 1364 750"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <circle cx="674" cy="356" r="477.5" stroke="currentColor"></circle>
          <circle opacity="0.6" cx="674" cy="356" r="551.5" stroke="currentColor"></circle>
          <circle opacity="0.4" cx="674" cy="356" r="629.5" stroke="currentColor"></circle>
          <circle opacity="0.2" cx="674" cy="356" r="701.5" stroke="currentColor"></circle>
        </svg>
      </div>
    </Fragment>

    <Fragment slot="author">
      <span class="c-metadata__author">By{" "}
        {post.data.authorUrl ? (
          <a
            href={post.data.authorUrl}
            class="underline hover:text-[var(--scheme-accent)]"
            target="_blank"
            rel="noreferrer"
          >{post.data.author}</a>
        ) : (
          post.data.author
        )}
      </span>
      <span class="c-metadata__dot"></span>
      <span class="c-metadata__date">{post.data.date.toLocaleDateString()}</span>
    </Fragment>

    <Fragment slot="tags">
      {postTags.length > 0 && (
        <div>
          <span class="h-1 w-1 rounded-full bg-[var(--scheme-accent)]" />
          <span class="flex flex-wrap gap-1">
            {postTags.map((tag) => (
              <a
                href={`${resourceType.tagBasePath}/${encodeURIComponent(tag)}`}
                class="c-label c-label--small c-label--light-grey c-label--lower c-label--filter"
              >{tag}</a>
            ))}
          </span>
        </div>
      )}
    </Fragment>

    <Fragment slot="content">
      <Content />
    </Fragment>
  </ResourceDetailArticle>

  {morePosts.length > 0 && (
    <MoreItemsGrid title={resourceType.moreTitle} gridId="more-blog-grid">
      {morePosts.map((p) => (
        <MoreItemCard
          {...buildMoreItemCardProps(p, resourceType.detailBasePath, resourceType.moreCard)}
        />
      ))}
    </MoreItemsGrid>
  )}
</DocsLayout>
