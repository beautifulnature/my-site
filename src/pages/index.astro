---
// Importing the deeply consolidated, universally theme-aware components framework
import LandingHeader from "../components/landing/LandingHeader.astro";
import LandingHero from "../components/landing/LandingHero.astro";
import LandingShortcut from "../components/landing/LandingShortcut.astro";
import LandingAPIs from "../components/landing/LandingAPIs.astro";
import LandingFeatures from "../components/landing/LandingFeatures.astro";
import LandingIntelligence from "../components/landing/LandingIntelligence.astro";
import LandingProof from "../components/landing/LandingProof.astro";
import LandingPlatform from "../components/landing/LandingPlatform.astro";
import LandingCTA from "../components/landing/LandingCTA.astro";
import Footer from "../components/landing/LandingFooter.astro";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Timefold - Intelligent Scheduling</title>
    <!-- Critical inline script to avoid Flash of Unstyled Content (FOUC) -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'light'; // Light is the explicitly requested default
      })();
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="bg-white dark:bg-[#0b0f19] text-gray-900 dark:text-slate-300 font-sans antialiased overflow-x-hidden selection:bg-[#5A32FA] selection:text-white dark:selection:bg-[#10b981] dark:selection:text-[#0b0f19] pb-0 mb-0 transition-colors duration-300">
    
    <!-- Render universal UI that instantly adapts to tailwind .dark class natively! -->
    <LandingHeader />
    <main>
      <LandingHero />
      <LandingShortcut />
      <LandingAPIs />
      <LandingFeatures />
      <LandingIntelligence />
      <LandingProof />
      <LandingPlatform />
      <LandingCTA />
    </main>
    <Footer />

  </body>
</html>
